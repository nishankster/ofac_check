# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to source control.

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-32-byte-random-hex-string

# Comma-separated list of valid API keys your clients will exchange for JWTs
API_KEYS=key-replace-me-1,key-replace-me-2

# Optional — token lifetime in minutes (default: 60)
JWT_EXPIRE_MINUTES=60
